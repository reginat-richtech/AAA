# =====================================================================
# AAA_Database :: deployment environment config (TEMPLATE)
# ---------------------------------------------------------------------
# HOW TO USE:
#   cp .env.example .env.production      # (or .env.staging, .env.dev)
#   ...fill in the values...
#   ./deploy/deploy.sh production        # applies schema + seeds + login roles
#
# This template is committed. Filled-in files (.env, .env.production, ...)
# are gitignored and MUST NEVER be committed. Real secrets belong in your
# platform's secret manager (AWS Secrets Manager, GCP Secret Manager, Vault,
# Render/Fly secrets, etc.); this file documents what those secrets are named.
# Lines marked SECRET must come from the secret manager, not live here in prod.
# =====================================================================

# Which environment this file describes (informational / logging)
DEPLOY_ENV=production

# ---- ADMIN connection: used ONCE to apply migrations + create roles --------
# Use the "master"/admin user your managed-Postgres provider gave you.
PGHOST=your-instance.xxxxxxxx.us-east-1.rds.amazonaws.com
PGPORT=5432
PGDATABASE=aaa
PGADMIN_USER=postgres
PGADMIN_PASSWORD=CHANGE_ME                 # SECRET — provider master password
PGSSLMODE=verify-full                      # require (encrypt) | verify-full (encrypt + verify cert, recommended)
PGSSLROOTCERT=deploy/certs/server-ca.pem   # provider's CA cert, needed for verify-full (download from console)

# ---- Application login-role passwords (created by deploy/roles.sql) --------
APP_RW_PASSWORD=CHANGE_ME                   # SECRET — read/write user your app uses
APP_RO_PASSWORD=CHANGE_ME                   # SECRET — read-only user for reporting

# ---- What your APPLICATION uses at runtime (connects as the RW login user) -
# Your app/framework usually reads one URL. sslmode is required for security.
# Compose it from APP_RW_PASSWORD + PGHOST above:
APP_DATABASE_URL=postgresql://app_rw:APP_RW_PASSWORD@your-host:5432/aaa?sslmode=verify-full

# ---- Column-encryption keys (for sec.encrypt / sec.blind_index) ------------
# In production, FETCH these from a KMS at runtime and SET them per database
# session (SET app.enc_key = ...). Do NOT bake real keys into a deployed file.
APP_ENC_KEY=from-kms                        # SECRET
APP_BLIND_INDEX_KEY=from-kms                # SECRET (separate key from APP_ENC_KEY)
